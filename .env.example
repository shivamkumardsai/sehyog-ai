# Google Gemini API key for medical report analysis
GEMINI_API_KEY=your_gemini_api_key_here

# MongoDB database URL for Prisma
# Example: mongodb+srv://<username>:<password>@cluster0.mongodb.net/mydatabase?retryWrites=true&w=majority
DATABASE_URL="mongodb+srv://<username>:<password>@cluster0.mongodb.net/mydatabase?retryWrites=true&w=majority"

# NextAuth secret — generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here

# App URL (required for NextAuth in production)
NEXTAUTH_URL=http://localhost:3000
